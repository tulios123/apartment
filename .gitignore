# audit run artifacts
e2e/.results/
docs/audit/evidence/

# Local secrets — never commit. `.env.local` is already covered by *.local above; these
# explicit rules make the protection travel with the repo instead of depending on a
# machine's global gitignore (which is what held .claude/settings.local.json until now —
# it carries a real SUPABASE_ACCESS_TOKEN).
.env
.env.*
!.env.example
.claude/settings.local.json
