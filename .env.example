# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to `.env.local` and fill in. `.env.local` is gitignored.
# Vite inlines every VITE_* var into the shipped bundle, so treat them all as PUBLIC.
# Real secrets (service-role key, Anthropic key, VAPID private key, GitHub PAT, CRON
# secret) are NOT client vars — they live only as Supabase Edge Function secrets and
# as GitHub Actions secrets. They must never appear in this file or any committed file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required to run the app (dev + build) ────────────────────────────────────
# From the Supabase project → Settings → API. The anon key is public-by-design
# (all access is gated by row-level security). Without these two the app throws at
# load (src/lib/supabase.ts). Point them at the hosted project to reuse its data.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Web push (optional; Stage B feature) ─────────────────────────────────────
# Public VAPID key — generate a pair with `npx web-push generate-vapid-keys`.
# The PRIVATE key + VAPID_SUBJECT live as Supabase function secrets, never here.
VITE_VAPID_PUBLIC_KEY=
# Set to "true" in .env.local to register the service worker under `npm run dev`.
VITE_ENABLE_SW_DEV=

# ── Build flavor (optional) ──────────────────────────────────────────────────
# CI sets VITE_APP_ENV=staging for the staging deploy (orange banner + staging name
# + the "promote to everyone" area). Leave unset for a production-flavored build.
VITE_APP_ENV=

# ── Admin gating (optional) ──────────────────────────────────────────────────
# Comma-separated extra admin emails that see the feedback-admin UI. Not a secret,
# but real addresses — leave blank unless you need it locally.
VITE_FEEDBACK_ADMIN_EMAILS=

# ── Dev-only auto-login (optional; compiled out of any production build) ──────
# Gated on import.meta.env.DEV, so it can never reach a prod bundle; `build:prod`
# also blanks these as a guard. Set them to a test account to skip the login screen
# under `npm run dev` (used by the Playwright e2e specs). NEVER a real user password.
VITE_DEV_BYPASS_AUTH=
VITE_DEV_USER_EMAIL=
VITE_DEV_USER_PASSWORD=

# ── Supabase CLI (optional; migrations / function deploys only) ───────────────
# A personal access token for the `supabase` CLI (Account → Access Tokens). SECRET.
# Only needed if you push migrations or deploy edge functions from this machine.
# Not read by any app code — export it in your shell or keep it in .env.local.
SUPABASE_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE SECRETS — do NOT put these here. They are set with
#   `supabase secrets set KEY=value`  (per Edge Function), and as GitHub Actions
# repo secrets for CI. Listed for reference so the backend can be reconstructed:
#
#   Supabase function secrets (supabase/functions/*):
#     SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY   admin server client
#     ANTHROPIC_API_KEY                          doc-extraction (extract-* fns)
#     VAPID_PRIVATE_KEY, VAPID_PUBLIC_KEY, VAPID_SUBJECT   web-push send
#     CRON_SECRET                                auth for the daily-reminders cron caller
#     PIPELINE_SECRET                            GitHub Actions → Supabase callback auth
#     GITHUB_PAT, GITHUB_REPO                    open issues/PRs (feedback→Claude pipeline)
#     FEEDBACK_ADMIN_EMAIL(S), FEEDBACK_NOTIFY_EMAIL   feedback routing
#     CLIENT_THREAD_URL_TEMPLATE                 deep-link template for reply notifications
#
#   GitHub Actions repo secrets (.github/workflows/*):
#     VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_FEEDBACK_ADMIN_EMAILS   build env
#     CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID   Pages deploy
#     PIPELINE_SECRET, CLAUDE_CODE_OAUTH_TOKEN      feedback-autofix pipeline
# ─────────────────────────────────────────────────────────────────────────────
