VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Web push (Stage B). Public VAPID key — generate with `npx web-push generate-vapid-keys`.
# The matching private key + VAPID_SUBJECT + CRON_SECRET live as Supabase function secrets, never here.
VITE_VAPID_PUBLIC_KEY=
# Optional: set to "true" in .env.local to register the service worker under `npm run dev`.
VITE_ENABLE_SW_DEV=
